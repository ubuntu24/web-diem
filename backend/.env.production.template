# --- DATABASE CONFIG ---
# Direct connection string for Supabase Postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/[DBNAME]

# --- SECURITY CONFIG ---
# Generate a strong secret key using: python -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=[YOUR_SECRET_KEY]

# Global admin account password
ADMIN_PASSWORD=[YOUR_ADMIN_PASSWORD]

# --- NETWORK & CORS ---
# Domain of your frontend (e.g. https://webdiem.com)
ALLOWED_ORIGINS=http://localhost:3000

# Trusted hostnames (comma separated)
EXTRA_TRUSTED_HOSTS=localhost,127.0.0.1

# Environment mode (production/development)
NODE_ENV=production

# --- TELEGRAM BOT (Optional) ---
TELEGRAM_BOT_TOKEN=[YOUR_BOT_TOKEN]
TELEGRAM_CHAT_ID=[YOUR_CHAT_ID]
